set number              
set relativenumber      
set cursorline          
set showmatch

set tabstop=4
set softtabstop=4
set shiftwidth=4
set expandtab
set smartindent

set hlsearch
set ignorecase
set smartcase
set incsearch

set mouse=a
set clipboard=unnamed
set noswapfile
set history=1000
set encoding=utf-8

let mapleader="\<Space>"

nnoremap <leader>w :write<cr>
nnoremap <leader>h :nohl<cr>
inoremap jj <Esc>
nnoremap <silent> <Space><Enter> :noh<CR>